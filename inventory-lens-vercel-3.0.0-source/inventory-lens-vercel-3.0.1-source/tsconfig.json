{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "chrome", "vite/client", "vitest/globals"]
  },
  "include": [
    "api",
    "server",
    "src",
    "tests",
    "vite.config.ts",
    "vite.web.config.ts"
  ]
}
